# ---- Required for the highlighter + heatmap backend ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Required for audio / Wonjune paralinguistic encoder ----
# Path to a Wonjune checkpoint .pt file. Download from the Google Drive link
# in expressive-speech-retrieval/README.md. Without this, audio-scoped
# features (ingestion, style retrieval) are disabled; Cortico-JSON-only
# conversations still work.
WONJUNE_CHECKPOINT_PATH=
# Path to the matching config YAML (relative to expressive-speech-retrieval/).
WONJUNE_CONFIG=config/roberta_emotion2vec.yaml
# Override if the repo lives elsewhere on disk.
# WONJUNE_REPO_DIR=../expressive-speech-retrieval
# cpu | cuda
WONJUNE_DEVICE=cpu

# ---- Anthropic model routing (override to swap models) ----
# ANTHROPIC_SNIPPET_MODEL=claude-opus-4-7
# ANTHROPIC_SPAN_MODEL=claude-sonnet-4-6
# ANTHROPIC_PLANNER_MODEL=claude-sonnet-4-6
# ANTHROPIC_EXPLAIN_MODEL=claude-sonnet-4-6

# ---- ASR (faster-whisper) ----
# tiny | base | small | medium | large-v3
WHISPER_MODEL=medium
# float16 | int8 | int8_float16 (pick one supported by your device)
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# ---- Topical embedder ----
# TOPIC_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Data directory (defaults to ./data) ----
# DATA_DIR=./data
